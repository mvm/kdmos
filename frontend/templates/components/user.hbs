<div>
  {{#if isLogged}}
    {{i18n 'Hello'}} {{currentUser}}
    <input type="button" id='logoutbutton' value="{{i18n 'logout'}}"></input>
  {{else}}
    <div class="nav-item dropdown">
      <a class="nav-link dropdown-toggle" role="button" id="loginDrop" data-toggle="dropdown">{{ i18n 'Login' }}
        <span class="caret"></span></a>
      <div class="dropdown-menu" role="menu" aria-labelledby="loginDrop">
        <form class="px-3 py-2" role="menuitem" tabindex="-1">
          <div class="form-group">
            <label for="loginEmail">{{ i18n "Email" }}</label>
            <input type="text" class="form-control" id="loginEmail" placeholder="{{i18n 'Email'}}"><br>
          </div>
          <div class="form-group">
            <label for="loginPass">{{i18n 'Password'}}</label>
            <input type="password" id="loginPass" class="form-control" placeholder="{{i18n 'Password'}}"><br>
          </div>
          <input type="button" class="btn" id="loginSubmit" value="{{i18n 'Login'}}"/>
        </form>
        <div class="dropdown-divider"></div>
        <a class="dropdown-item" href="#register">{{i18n 'New?'}}<br>{{i18n 'Sign up'}}</a>
      </div>
    </div>
  {{/if}}
</div>
