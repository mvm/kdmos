<span>
	<div class="container mt-3" id="main">
				<div class="row">
					<div class="col">
						<div class="container-fluid mt-3 mb-3">
							<div align="center">						
								<h4 class="header" >{{ survey.title }}</h4>
							</div>
							<div align="left">
								<p>{{ survey.description }}</p>
							</div>
							
							<div class="container" align="center">	
							{{#if showMode}}
							<p><div class="divTable Tabla">

								<div class="divTableRow">
									<div class="divTableCell corner"></div>
									{{votes.[0].survey_option.id}}									
									{{#each votes}}
									{{#if vote.survey_option.id == votes.[0].survey_option.id }}
										<div class="divTableCell d-none d-sm-table-cell">{{ vote.user.name." ".vote.user.surname}}</div>
									{{/if}}
									{{/each}}
										<div class="divTableCell">Total</div>
								</div>
								<div class="divTableRow">
								<div class="divTableCell">{{votes.[0].survey_option.day->format("Y-m-d")." ".votes.[0].survey_option.start->format("H:i:s")."-".votes.[0].survey_option.end->format("H:i:s")}}</div>
									<script> var total=0 </script>
										{{#each votes}}
											{{#if vote.survey_option.id == votes.[0].survey_option.id}}
												<div class="divTableCell d-none d-sm-table-cell">
												<script type="text/javascript">
												  var valor = vote.vote;
													switch (valor){
														case "Y":
															document.write("<i class='fas fa-2x fa-check option'></i>");
															total+=1;
															break;
														case "N":
															document.write("<i class='fas fa-2x fa-times option'></i>");
															break;
														default:
															document.write("<i class='fas fa-2x fa-question option'></i>");		
													}
												</script></div>
											{{else}}
												<div class="divTableCell" id="total"><script type="text/javascript">document.getElementById("total").innerHTML = total </script></div>
												</div>											
												<script> total=0 </script>
											<div class="divTableRow">
												<div class="divTableCell">
													{{vote.survey_option.day->format("Y-m-d")." ".vote.survey_option.start->format("H:i:s")."-".votes.survey_option.end->format("H:i:s")}}</div>
												<div class="divTableCell d-none d-sm-table-cell">
													<script type="text/javascript">
													var valor = vote.vote;
													switch (valor){
														case "Y":
															document.write("<i class='fas fa-2x fa-check option'></i>");
															total+=1;
															break;
														case "N":
															document.write("<i class='fas fa-2x fa-times option'></i>");
															break;
														default:
															document.write("<i class='fas fa-2x fa-question option'></i>");		
													}
												</script></div>
												<div class="divTableCell" id="total"><script type="text/javascript">document.getElementById("total").innerHTML = total </script></div>
												</div>{{/each}}
							</div></p>
							{{else}}
							<form action="index.php?controller=votes&amp;action=add&amp;survey_id={{ echo $survey->getId();}}" id="votar" method="POST">
							<p><div class="divTable Tabla">								
								{{#each votes}}
									<div class="divTableRow">
                                        <div class="divTableCell">{{vote.survey_option.day->format("Y-m-d")." ".vote.survey_option.start->format("H:i:s")."-".votes.survey_option.end->format("H:i:s")}}</div>
										<div class="divTableCell">
												<select class="custom-select" name="all_votes[]">
													<option selected value="NS">Elige</option>
													<option value="Y">Sí</option>
													<option value="N">No</option>
													<option value="NS">Podría ser</option>
												</select>
										</div></div>
								</div>{{/each}}
							</div></p>
							{{/if}}
							{{#if showMode}}
							<button type="button" class="btn btn-light" id="votelink">{{i18n 'Vote'}}</button>
							{{else}}
							<button type="submit" class="btn btn-light" name="submit" form="votar">{{i18n 'Vote'}}</button>
							{{/if}}
							<button onclick="goBack()"class="btn btn-light">{{i18n 'Go Back'}}</button>
							<script>
									function goBack() {
										window.history.back();
									}
							</script>
							<div>{{ i18n 'Link: ';  echo $_SERVER["HTTP_HOST"];echo $_SERVER["REQUEST_URI"];}}</div>
						</div>
					</div>
				</div>
			</div>
</span>